# ============================================================
# Predict.fun Secure Market Maker - Environment Configuration
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file to .env: cp .env.example .env
#   2. Fill in YOUR values (never commit .env to git)
#   3. Run with DRY_RUN=true first to verify config
#   4. Use a SEPARATE wallet with MINIMAL funds for testing
# ============================================================

# --- Platform API ---
API_BASE_URL=https://api.predict.fun
API_KEY=REPLACE_WITH_YOUR_API_KEY

# --- JWT (obtain via: npm run auth:jwt) ---
JWT_TOKEN=

# --- Wallet ---
# WALLET_MODE: EOA (raw private key) | EXTERNAL (not yet implemented)
# WARNING: EOA mode stores the private key in process memory.
#          Use a dedicated trading wallet with limited funds.
WALLET_MODE=EOA
PRIVATE_KEY=REPLACE_WITH_YOUR_PRIVATE_KEY
PREDICT_ACCOUNT_ADDRESS=

# --- RPC ---
RPC_URL=

# --- Safety Defaults ---
DRY_RUN=true
ENABLE_TRADING=false
AUTO_CONFIRM=false
MAX_DAILY_LOSS_USD=200
MAX_POSITION_USD=100
MAX_SINGLE_ORDER_USD=50

# --- Market Maker ---
SPREAD=0.02
MIN_SPREAD=0.01
MAX_SPREAD=0.08
ORDER_SIZE_USD=10
REFRESH_INTERVAL_MS=5000

# --- Arbitrage ---
ARB_AUTO_EXECUTE=false
ARB_MIN_PROFIT_PCT=0.02
ARB_SCAN_INTERVAL_MS=10000
ARB_MAX_MARKETS=80

# --- Circuit Breaker ---
CIRCUIT_MAX_FAILURES=3
CIRCUIT_WINDOW_MS=60000
CIRCUIT_COOLDOWN_MS=60000

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS_PER_SEC=5
RATE_LIMIT_ORDERS_PER_MIN=30

# --- Alerts (optional webhook URL) ---
ALERT_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=info

# --- Market Filter (comma-separated token IDs, empty = auto-select) ---
MARKET_TOKEN_IDS=
