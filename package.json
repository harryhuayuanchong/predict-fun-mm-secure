{
  "name": "predict-fun-mm-secure",
  "version": "1.0.0",
  "description": "Secure market maker and arbitrage bot for prediction markets",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start:mm": "node --import tsx src/cli/start-mm.ts",
    "start:arb": "node --import tsx src/cli/start-arb.ts",
    "auth:jwt": "node --import tsx src/cli/auth-jwt.ts",
    "smoke": "node --import tsx src/cli/smoke-test.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": ["market-maker", "arbitrage", "prediction-markets"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "ws": "^8.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
